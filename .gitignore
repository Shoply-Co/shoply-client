# dependencies
node_modules/
.pnpm-store/
.turbo/

# Expo
.expo/
apps/*/.expo/
dist/
web-build/
expo-env.d.ts
apps/*/expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files; shared public defaults may live in .env or .env.development
.env*.local
fastlane/.env
fastlane/.env.*
!fastlane/.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
apps/*/android

# Ruby / Fastlane artifacts
.bundle/
vendor/bundle/
/artifacts/ios/
fastlane/report.xml
fastlane/Preview.html
