    "babel-preset-expo": "~57.0.2",
    "msw": "^2.14.6",
    "orval": "^8.20.0"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate:api": "orval --config ./orval.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "doctor": "npx expo-doctor@latest",
    "build": "expo export --platform all",
    "eas:init": "npx eas-cli@latest init --id 83466a33-b79d-4ded-aa8e-dda1c2c91e64",
    "eas:build:development": "npx eas-cli@latest build --profile development",
    "eas:build:preview": "npx eas-cli@latest build --profile preview",
    "eas:build:testflight": "npx eas-cli@latest build --profile testflight --platform ios",
    "eas:build:production": "npx eas-cli@latest build --profile production",
    "eas:submit:testflight": "npx eas-cli@latest submit --profile testflight --platform ios",
    "eas:submit:production": "npx eas-cli@latest submit --profile production",
    "eas:update:preview": "npx eas-cli@latest update --channel preview --environment preview",
    "eas:update:production": "npx eas-cli@latest update --channel production --environment production"
  }
}
