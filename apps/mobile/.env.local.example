# Copy to .env.local when this machine needs overrides.
# Shared public development defaults live in .env.development.
# Do not put secrets here; EXPO_PUBLIC_* values are bundled into the app.

# Local backend override for a physical device/dev client.
# Use your current ngrok HTTPS domain when the backend is running locally.
# EXPO_PUBLIC_API_BASE_URL=https://your-ngrok-domain.ngrok-free.app/v1
# EXPO_PUBLIC_ANDROID_API_BASE_URL=https://your-ngrok-domain.ngrok-free.app/v1

# EAS profiles use these public API hosts:
# production: https://api.shopplyapp.com/v1
# preview/testflight: https://staging-api.shopplyapp.com/v1

# OAuth/deep-link override
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=shoply://auth/callback
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# EXPO_PUBLIC_KAKAO_REST_API_KEY=
# EXPO_PUBLIC_KAKAO_JAVASCRIPT_KEY=
# EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=
# EXPO_PUBLIC_KAKAO_SCHEME=shoply
# EXPO_PUBLIC_KAKAO_LOGIN_ENABLED=true

# Local development-only auth shortcut
# EXPO_PUBLIC_DEV_AUTH_ENABLED=true
